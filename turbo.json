{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "assets/diagram-*.svg",
    "content/**",
    "design-system/**",
    "reports/freshness.json",
    "reports/release-readiness.json",
    "reports/review-queue.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "validate": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "reports/**"
      ]
    }
  }
}
