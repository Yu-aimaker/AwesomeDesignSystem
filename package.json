{
  "name": "awesome-design-system",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && pnpm exec tsc --noEmit --project tsconfig.base.json",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:a11y": "playwright test tests/a11y",
    "test:e2e": "playwright test tests/e2e tests/visual",
    "validate": "turbo run validate",
    "qa": "pnpm typecheck && pnpm lint && pnpm test && pnpm validate && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "24.3.0",
    "turbo": "2.5.6",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "yaml": "2.8.1"
  }
}
