{
  "name": "@awesome-ds/react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "development": "./src/index.ts", "import": "./dist/index.js" },
    "./contracts": { "types": "./src/contracts.ts", "development": "./src/contracts.ts", "import": "./dist/contracts.js" },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "build": "tsup src/index.ts src/contracts.ts --format esm --dts --clean --external react --external react-dom"
  },
  "dependencies": {
    "@awesome-ds/core": "workspace:*",
    "@awesome-ds/motion": "workspace:*",
    "@awesome-ds/tokens": "workspace:*",
    "react-aria-components": "1.19.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "26.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  }
}
