{
  "name": "@awesome-ds/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "development": "./src/index.ts", "import": "./dist/index.js" },
    "./contracts": { "types": "./src/component-contracts.ts", "development": "./src/component-contracts.ts", "import": "./dist/component-contracts.js" },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "build": "tsup src/index.ts src/component-contracts.ts --format esm --dts --clean"
  },
  "devDependencies": {
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  }
}
