{
  "name": "@awesome-ds/motion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "development": "./src/index.ts", "import": "./dist/index.js" },
    "./react": { "types": "./src/react.ts", "development": "./src/react.ts", "import": "./dist/react.js" },
    "./recipes.css": "./src/recipes.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "build": "tsup src/index.ts src/react.ts --format esm --dts --clean --external react"
  },
  "dependencies": {
    "@awesome-ds/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "19.1.10",
    "react": "19.1.1",
    "typescript": "5.9.2",
    "vitest": "4.1.10"
  }
}
