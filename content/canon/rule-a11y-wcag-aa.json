{
  "id": "rule.a11y.wcag-aa",
  "title": "Meet WCAG 2.2 AA by default",
  "domain": "accessibility",
  "summary": "Accessibility is a release gate, not a polish pass.",
  "guidance": "Every interactive surface must meet WCAG 2.2 AA for contrast, keyboard, name, and operable paths.",
  "do": [
    "Run axe on representative pages",
    "Keyboard-only smoke every complex widget"
  ],
  "dont": [
    "Mouse-only flows",
    "Icon buttons without accessible names"
  ],
  "referenceIds": [
    "ref.a11y.axe-core",
    "ref.adobe.react-aria",
    "ref.apple.hig",
    "ref.apple.hig-accessibility",
    "ref.baseui.base-ui",
    "ref.govuk.design-system",
    "ref.radix.primitives",
    "ref.smarthr.design",
    "ref.uswds.uswds",
    "ref.w3c.apg",
    "ref.w3c.wcag-22",
    "ref.w3c.wcag-3"
  ],
